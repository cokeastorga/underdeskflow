rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Auth context helpers
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Validates that the logged-in user has the custom claim `storeId` matching the document's `storeId`
    function isTenantAdmin(targetStoreId) {
      return isAuthenticated() && request.auth.token.storeId == targetStoreId;
    }

    match /users/{uid} {
      allow read, write: if request.auth != null && (request.auth.uid == uid || request.auth.token.email == "jor.astorga@ccsolution.cl");
    }

    match /users {
      // Allow checking if the database is empty during registration
      allow list: if request.auth != null && request.query.limit <= 1;
    }

    match /stores/{storeId} {
      allow read: if isTenantAdmin(storeId);
      allow write: if isTenantAdmin(storeId);
    }
    
    // Public Catalog (Readable for storefront, protected for writes)
    match /categories/{docId} {
      allow read: if true; 
      allow write: if isTenantAdmin(resource.data.storeId) || isTenantAdmin(request.resource.data.storeId);
    }
    
    match /products/{docId} {
       allow read: if true;
       allow write: if isTenantAdmin(resource.data.storeId) || isTenantAdmin(request.resource.data.storeId);
    }
    
    match /variants/{docId} {
       allow read: if true;
       allow write: if isTenantAdmin(resource.data.storeId) || isTenantAdmin(request.resource.data.storeId);
    }

    // INTERNAL/SENSITIVE DOMAINS (Strict isolation)
    match /inventory_movements/{docId} {
       allow read, write: if isTenantAdmin(resource.data.storeId) || isTenantAdmin(request.resource.data.storeId);
    }
    
    match /orders/{docId} {
       allow read: if isTenantAdmin(resource.data.storeId);
       allow write: if isTenantAdmin(resource.data.storeId) || isTenantAdmin(request.resource.data.storeId);
    }

    match /payment_intents/{docId} {
       allow read, write: if isTenantAdmin(resource.data.storeId) || isTenantAdmin(request.resource.data.storeId);
    }

    match /payments_ledger/{docId} {
       allow read, write: if isTenantAdmin(resource.data.storeId) || isTenantAdmin(request.resource.data.storeId);
    }

    // FINANCIALS / PAYOUTS (Highly restricted, written via Admin SDK only ideally)
    match /platform_fees/{docId} {
       allow read: if isTenantAdmin(resource.data.storeId);
       allow write: if false; // Only written by secure Backend Workers/Webhooks
    }

    match /payout_batch/{docId} {
       allow read: if isTenantAdmin(resource.data.storeId);
       allow write: if false; // Only written by Scheduled Cron Workers
    }

    match /system_errors/{docId} {
        allow read, write: if false; // Internal logger only
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
